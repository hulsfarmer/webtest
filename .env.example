# Claude API (필수 - 스크립트 생성)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Google Cloud TTS (권장 - 자연스러운 한국어 Neural2 음성)
# 무료 발급: https://console.cloud.google.com/apis/library/texttospeech.googleapis.com
# SSML timepoints로 정확한 자막 타이밍 지원
GOOGLE_TTS_API_KEY=

# OpenAI TTS (선택 - Google Cloud TTS 없을 때 2순위 fallback)
OPENAI_API_KEY=sk-...

# Pexels API (선택 - 동영상 배경, 없으면 그라디언트 사용)
# 무료 발급: https://www.pexels.com/api/
PEXELS_API_KEY=

# Stripe (결제 기능 사용 시)
# 대시보드에서 상품/가격 생성 후 Price ID 복사: https://dashboard.stripe.com/test/products
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...          # stripe listen --forward-to localhost:3000/api/stripe/webhook
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_BASIC_PRICE_ID=price_...          # Basic $19/월 Price ID
STRIPE_PRO_PRICE_ID=price_...            # Pro $49/월 Price ID

# 앱 URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
