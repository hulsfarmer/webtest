# Claude API (필수 - 스크립트 생성)
ANTHROPIC_API_KEY=sk-ant-api03-...

# Google Cloud TTS (권장 - 자연스러운 한국어 Neural2 음성)
# 무료 발급: https://console.cloud.google.com/apis/library/texttospeech.googleapis.com
GOOGLE_TTS_API_KEY=

# OpenAI TTS (선택 - Google Cloud TTS 없을 때 2순위 fallback)
OPENAI_API_KEY=sk-...

# Pexels API (선택 - 동영상 배경, 없으면 그라디언트 사용)
# 무료 발급: https://www.pexels.com/api/
PEXELS_API_KEY=

# ─── NextAuth (인증) ───
NEXTAUTH_SECRET=your-random-secret-here    # openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# Google OAuth
# 발급: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Kakao OAuth
# 발급: https://developers.kakao.com/console/app
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# ─── Supabase (DB) ───
# 프로젝트 Settings > API에서 확인
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...

# ─── Stripe (결제) ───
# 대시보드에서 상품/가격 생성 후 Price ID 복사: https://dashboard.stripe.com/test/products
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...          # stripe listen --forward-to localhost:3000/api/stripe/webhook
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_BASIC_PRICE_ID=price_...          # 베이직 ₩19,900/월 Price ID
STRIPE_PRO_PRICE_ID=price_...            # 프로 ₩49,900/월 Price ID

# 앱 URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin Dashboard (콤마로 여러 이메일 가능)
ADMIN_EMAILS=admin@example.com
